# Cyber Sensei Backend Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=Cyber Sensei
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development  # development, staging, production

# Security - REQUIRED
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long-change-this

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cyber_sensei
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AI/LLM (Optional - for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Vector DB
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cyber_sensei

# Learning Algorithms
BKT_INITIAL_MASTERY=0.3
BKT_LEARN_RATE=0.1
BKT_GUESS_RATE=0.2
BKT_SLIP_RATE=0.1
SM2_INITIAL_EASINESS=2.5
SM2_MIN_EASINESS=1.3

# Content Moderation
ENABLE_CONTENT_MODERATION=True
AUTO_FLAG_THRESHOLD=0.7

# Lab Orchestrator (Disabled by default)
LAB_ENABLED=False
LAB_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_LABS=10
